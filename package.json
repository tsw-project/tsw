{
    "name": "@tsw-project/tsw",
    "version": "0.0.1",
    "description": "MapleStory Worlds TypeScript toolchain.",
    "type": "module",
    "main": "./dist/index.js",
    "bin": {
        "tsw": "./dist/index.js"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "start": "bun run src/index",
        "build": "bun build src/index.ts --outdir dist --target node --packages external '--banner=#!/usr/bin/env node'",
        "biome:fix": "biome check --write ."
    },
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.1"
    },
    "dependencies": {
        "commander": "^15.0.0",
        "typescript": ">=5",
        "typescript-to-lua": "^1.37.0"
    }
}
